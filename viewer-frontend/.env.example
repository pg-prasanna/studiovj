# ==========================================
# Studio VJ Viewer (Photograph) — Environment
# ==========================================
# 1. Copy this file:  cp .env.example .env.local
# 2. Update values for your environment
# 3. NEVER commit .env.local to version control
# ==========================================

# ---- API ----------------------------------------------------------
# Full URL to the backend API (including /api path)
# Local dev:  http://localhost:8080/api
# Production: https://api.yourdomain.com/api
VITE_API_BASE_URL=http://localhost:8080/api

# ---- Dev server port (optional) -----------------------------------
# VITE_PORT=5173

# ---- App metadata -------------------------------------------------
VITE_APP_TITLE=Studio VJ - Photo Gallery
VITE_APP_VERSION=1.0.0

# ---- Feature flags ------------------------------------------------
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_DATA=false

# ---- Branding -----------------------------------------------------
VITE_SITE_TITLE=Studio VJ Photography
VITE_SITE_DESCRIPTION=Professional Photography Portfolio
