# ==========================================
# Studio VJ Backend Environment Configuration
# ==========================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked <required>
# 3. NEVER commit .env to version control
# ==========================================

# Spring profile: 'dev' for local, 'prod' for production
SPRING_PROFILES_ACTIVE=dev

# ---- Server -------------------------------------------------------
SERVER_PORT=8080

# ---- Database -----------------------------------------------------
# For local dev use 'localhost'. For Docker use the service name, e.g. 'mysql'
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=photography_portfolio_dev
DATABASE_USER=root
DATABASE_PASSWORD=<required>         # your MySQL root / app user password

# ---- Cloudinary ---------------------------------------------------
# Sign up at https://cloudinary.com and copy from Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=<required>
CLOUDINARY_API_KEY=<required>
CLOUDINARY_API_SECRET=<required>

# ---- JWT ----------------------------------------------------------
# Generate with:  openssl rand -base64 48 | tr -d '\n'
# Use standard Base64 output (+/=) — NOT URL-safe (-_).
JWT_SECRET=<required>
JWT_EXPIRATION_MS=86400000           # 24 hours in milliseconds

# ---- CORS ---------------------------------------------------------
# Comma-separated list of allowed frontend origins (no trailing slash)
# Dev example:   http://localhost:5173,http://localhost:3001
# Prod example:  https://photo.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001

# ---- Logging ------------------------------------------------------
# Options: DEBUG | INFO | WARN | ERROR
LOGGING_LEVEL=DEBUG

# ---- Docker Compose: Frontend ports -------------------------------
ADMIN_PORT=3001
VIEWER_PORT=5173

# ---- Docker Compose: Frontend API URLs ----------------------------
# These are baked into the JS bundle at docker-compose build time.
# Must be the URL the user's BROWSER can reach — not the internal Docker hostname.
# Local Docker:  http://localhost:8080/api
# Production:    https://api.yourdomain.com/api
VITE_API_URL=http://localhost:8080/api
VITE_API_BASE_URL=http://localhost:8080/api
