# ==========================================
# Studio VJ — Root .gitignore
# ==========================================

# ---- Environment / Secrets ----------------------------------------
# NEVER commit real env files
**/.env
**/.env.local
**/.env.*.local
# Allow example files
!**/.env.example
!**/.env.docker

# ---- Build artifacts ----------------------------------------------
**/target/
**/dist/
**/build/
**/*.jar
**/*.war

# ---- Node -----------------------------------------------------------
**/node_modules/
**/.vite/
**/*.tsbuildinfo

# ---- IDE / OS -------------------------------------------------------
**/.idea/
**/.vscode/
**/*.iml
**/*.iws
**/.DS_Store
**/Thumbs.db
**/*.swp
**/*.swo

# ---- Logs -----------------------------------------------------------
**/logs/
**/*.log
**/*.log.*
npm-debug.log*
yarn-debug.log*

# ---- Maven ----------------------------------------------------------
**/pom.xml.tag
**/pom.xml.releaseBackup
**/dependency-reduced-pom.xml

# ---- Test coverage --------------------------------------------------
**/coverage/
**/.nyc_output/

# ---- Temp -----------------------------------------------------------
**/*.tmp
**/*.bak
**/.cache/
**/.eslintcache
